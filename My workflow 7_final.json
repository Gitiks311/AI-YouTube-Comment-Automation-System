    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const videoId = item.json.id?.videoId;\n  const title = item.json.snippet?.title;\n  const description = item.json.snippet?.description || '';\n  const channelTitle = item.json.snippet?.channelTitle;\n  const publishedAt = item.json.snippet?.publishedAt;\n\n  const content = `\nVideo Title: ${title}\nDescription: ${description}\nChannel: ${channelTitle}\nPublished: ${publishedAt}\nVideo ID: ${videoId}\n  `;\n\n  results.push({\n    json: {\n      video_id: videoId,\n      title: title,\n      content: content\n    }\n  });\n}\n\nreturn results;"
      },
