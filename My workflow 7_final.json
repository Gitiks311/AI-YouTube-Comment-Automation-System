    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst videoId = $('Code in JavaScript1').item.json.video_id;\n\nif (!item.items || item.items.length === 0) {\n  return [];\n}\n\nconst snippet = item.items[0].snippet;\nconst stats = item.items[0].statistics;\nconst details = item.items[0].contentDetails;\n\n// Get transcript - try different possible response fields\nlet transcriptRaw = '';\ntry {\n  const transcriptResponse = $('Get Transcript').item.json;\n  transcriptRaw = transcriptResponse?.body || \n                  transcriptResponse?.text || \n                  transcriptResponse?.data || \n                  JSON.stringify(transcriptResponse) || '';\n} catch(e) {\n  transcriptRaw = '';\n}\n\n// Clean XML tags from transcript\nconst transcriptText = transcriptRaw\n  .replace(/<[^>]+>/g, ' ')\n  .replace(/&amp;/g, '&')\n  .replace(/&#39;/g, \"'\")\n  .replace(/\\s+/g, ' ')\n  .trim()\n  .substring(0, 8000); // limit size\n\nconst content = `\nVideo Title: ${snippet.title}\n\nDescription: ${snippet.description || 'No description'}\n\nTags: ${snippet.tags ? snippet.tags.join(', ') : 'No tags'}\n\nDuration: ${details.duration || 'Unknown'}\n\nViews: ${stats.viewCount || '0'}\n\nLikes: ${stats.likeCount || '0'}\n\nPublished: ${snippet.publishedAt}\n\nChannel: ${snippet.channelTitle}\n\nTranscript: ${transcriptText || 'Transcript not available'}\n`;\n\nreturn [{\n  json: {\n    video_id: videoId,\n    title: snippet.title,\n    content: content\n  }\n}];"
      },
